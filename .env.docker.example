# Exemple d'environnement pour exécution sous Docker Compose.
# Copier en `.env` à la racine puis adapter.

# --- Django ---------------------------------------------------------------
SECRET_KEY=change-me-please
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=http://localhost:8000
CSRF_ALLOWED_ORIGINS=http://localhost:8000
CORS_ORIGINS_WHITELIST=http://localhost:8000

# --- Base de données (MariaDB via compose) --------------------------------
USE_SQLITE3=False
DB_NAME=ysem_project
DB_USER=ysem
DB_PASSWORD=ysem
DB_ROOT_PASSWORD=root
# DB_HOST et DB_PORT sont fixés par les fichiers docker-compose (db:3306)

# --- Email ----------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- reCAPTCHA ------------------------------------------------------------
RECAPTCHA_PUBLIC_KEY=
RECAPTCHA_PRIVATE_KEY=

# --- Divers ---------------------------------------------------------------
CLAMD_ENABLED=False
